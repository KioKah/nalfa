<div class="panel-section">
	<div class="field field--inline">
		<span class="field__label">ATK Arme</span>
		{{#if activeWeaponAttack}}
			<span class="field__value">{{activeWeaponAttack.value}} ({{activeWeaponAttack.label}})</span>
		{{else}}
			<span class="field__value">Non équipée</span>
		{{/if}}
	</div>
	{{#if sysData.equippable.main_hand}}
		<label class="field field--inline">
			<span class="field__label">Mp</span>
			<input
				class="fixed"
				name="system.attack.main_hand"
				type="number"
				value="{{sysData.attack.main_hand}}"
			/>
		</label>
	{{/if}}
	{{#if sysData.equippable.off_hand}}
		<label class="field field--inline">
			<span class="field__label">Ms</span>
			<input
				class="fixed"
				name="system.attack.secondary_hand"
				type="number"
				value="{{sysData.attack.secondary_hand}}"
			/>
		</label>
	{{/if}}
	{{#if sysData.equippable.two_handed}}
		<label class="field field--inline">
			<span class="field__label">2M</span>
			<input
				class="fixed"
				name="system.attack.two_hands"
				type="number"
				value="{{sysData.attack.two_hands}}"
			/>
		</label>
	{{/if}}
	<label class="field field--inline">
		<span class="field__label">Type de dégâts</span>
		<select class="fixed" name="system.damage_type" data-action="change-damage-type">
			{{#if (lookup config.fusion_damage_types sysData.damage_type)}}
				<option value="{{sysData.damage_type}}" data-special-damage-type="true" selected>
					{{lookup config.fusion_damage_types sysData.damage_type}}
				</option>
			{{/if}}
			{{selectOptions config.base_standard_damage_types selected=sysData.damage_type}}
			<option value="__special_damage_type__">Types spéciaux</option>
		</select>
	</label>
</div>

<div class="panel-section">
	<div class="field field--inline">
		<span class="field__label">Attributs d'arme</span>
		<button
			type="button"
			class="array-action-btn"
			data-action="add-array-entry"
			data-path="weapon_attributes.list"
			data-tooltip="Ajouter un attribut d'arme"
		>
			<i class="fa-light fa-square-plus"></i>
		</button>
	</div>
	{{#if sysData.weapon_attributes.list.length}}
		{{#each sysData.weapon_attributes.list as |attribute index|}}
			<div class="field field--inline">
				<select class="fixed" name="system.weapon_attributes.list.{{index}}">
					{{selectOptions @root.config.weapon_attributes selected=attribute}}
				</select>
				<button
					type="button"
					class="array-action-btn"
					data-action="remove-array-entry"
					data-path="weapon_attributes.list"
					data-index="{{index}}"
					data-tooltip="Supprimer cet attribut d'arme"
				>
					<i class="fa-light fa-square-minus"></i>
				</button>
			</div>
		{{/each}}
	{{else}}
		<p>Aucun attribut d'arme.</p>
	{{/if}}
	{{#if weaponWarnings.length}}
		<div class="field field--inline">
			<span class="field__label">Incompatibilités</span>
			<span class="field__value">{{weaponWarningText}}</span>
		</div>
	{{/if}}
</div>
