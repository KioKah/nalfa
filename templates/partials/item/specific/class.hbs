<div class="grid grid--two">
	<div class="panel-section">
		<label class="field">
			<span class="field__label">Stat ester</span>
			<select name="system.stat_ester">
				{{selectOptions config.stats selected=sysData.stat_ester}}
			</select>
		</label>

		<span class="field__label">Choix</span>
		<label class="field">
			<span class="field__label">Bonus points</span>
			<input
				name="system.choices.bonus_skill_points.value"
				type="number"
				value="{{sysData.choices.bonus_skill_points.value}}"
				data-dtype="Number"
			/>
			<span class="field__separator">/</span>
			<input
				name="system.choices.bonus_skill_points.max"
				type="number"
				value="{{sysData.choices.bonus_skill_points.max}}"
				data-dtype="Number"
			/>
		</label>
		<label class="field">
			<span class="field__label">Malus points</span>
			<input
				name="system.choices.malus_skill_points.value"
				type="number"
				value="{{sysData.choices.malus_skill_points.value}}"
				data-dtype="Number"
			/>
			<span class="field__separator">/</span>
			<input
				name="system.choices.malus_skill_points.max"
				type="number"
				value="{{sysData.choices.malus_skill_points.max}}"
				data-dtype="Number"
			/>
		</label>
	</div>

	<div class="panel-section">
		<span class="field__label">Attributs classe</span>
		<div class="grid grid--two">
			<label class="field">
				<span class="field__label">Main</span>
				<input
					name="system.attributes.actions.main"
					type="number"
					value="{{sysData.attributes.actions.main}}"
					data-dtype="Number"
				/>
			</label>
			<label class="field">
				<span class="field__label">Bonus</span>
				<input
					name="system.attributes.actions.bonus"
					type="number"
					value="{{sysData.attributes.actions.bonus}}"
					data-dtype="Number"
				/>
			</label>
			<label class="field">
				<span class="field__label">Réaction</span>
				<input
					name="system.attributes.actions.reaction"
					type="number"
					value="{{sysData.attributes.actions.reaction}}"
					data-dtype="Number"
				/>
			</label>
			<label class="field">
				<span class="field__label">Concentration</span>
				<input
					name="system.attributes.actions.concentration"
					type="number"
					value="{{sysData.attributes.actions.concentration}}"
					data-dtype="Number"
				/>
			</label>
			<label class="field">
				<span class="field__label">Mouvement</span>
				<input
					name="system.attributes.actions.movement"
					type="number"
					value="{{sysData.attributes.actions.movement}}"
					data-dtype="Number"
				/>
			</label>
		</div>

		<div class="field">
			<span class="field__label">Armor score</span>
			<input
				name="system.attributes.armor_score.base"
				type="number"
				value="{{sysData.attributes.armor_score.base}}"
				data-dtype="Number"
			/>
			<select name="system.attributes.armor_score.stat">
				{{selectOptions config.stats_optional selected=sysData.attributes.armor_score.stat}}
			</select>
			<span class="field__value">{{sysData.attributes.armor_score.value}}</span>
		</div>
	</div>
</div>
