<div class="attack-config__section attack-config__section--row">
  <div class="attack-config__section-title">
    <span class="field__label">Coût</span>
  </div>
  <div class="attack-config__fields attack-config__cost-row">
    <div class="attack-config__cost-entry attack-config__cost-entry--actions">
      <span class="attack-config__cost-label">Action</span>
      <div class="attack-config__action-costs attack-config__action-costs--column">
        {{#with (lookup actionData.cost.actions.options 0) as |firstOption|}}
          {{>
            "systems/nalfa/templates/partials/item/actionable/cost-action-option.hbs"
            actionPath=@root.actionPath
            option=firstOption
            optionIndex=0
            config=@root.config
            isPrimary=true
            readonly=@root.readonly
            showRemoveButton=false
            showConditionInput=(lookup @root.actionData.cost.actions.options 1)
          }}
        {{/with}}

        {{>
          "systems/nalfa/templates/partials/shared/richtext-section.hbs"
          title="Note"
          namePath=noteNamePath
          editTooltip="Modifier la note de coût"
          content=enrichedHTML.note
          hasContent=noteHasContent
          placeholderHtml="<p>Ex : Annulation Gratuite</p>"
          readonly=readonly
          contentClass="richtext-field richtext-field--overlay-action attack-config__action-note-field"
        }}

        <div class="attack-config__action-options-head">
          <span class="hint">Si plusieurs options :</span>
          {{#unless readonly}}
            <button
              type="button"
              class="array-action-btn"
              data-action="add-array-entry"
              data-path="{{actionPath}}cost.actions.options"
              data-entry-type="action-resource-option"
              data-tooltip="Ajouter une option de coût"
            >
              <i class="fa-light fa-square-plus"></i>
            </button>
          {{/unless}}
        </div>

        {{#each actionData.cost.actions.options as |option optionIndex|}}
          {{#unless @first}}
            {{>
              "systems/nalfa/templates/partials/item/actionable/cost-action-option.hbs"
              actionPath=@root.actionPath
              option=option
              optionIndex=optionIndex
              config=@root.config
              isPrimary=false
              readonly=@root.readonly
              showRemoveButton=true
              showConditionInput=true
            }}
          {{/unless}}
        {{/each}}
      </div>
    </div>

    <div class="attack-config__cost-entry attack-config__cost-entry--nalfa">
      <span class="attack-config__cost-label">Action de Déplacement</span>
      <select
        class="attack-config__cost-select attack-config__cost-select--movement"
        name="system.{{actionPath}}cost.movement.mode"
      >
        {{selectOptions config.action_movement_cost_modes selected=actionData.cost.movement.mode}}
      </select>
      {{#if (eq actionData.cost.movement.mode "fixed")}}
        <input
          class="attack-config__cost-input"
          name="system.{{actionPath}}cost.movement.amount"
          type="number"
          value="{{actionData.cost.movement.amount}}"
          data-dtype="Number"
        />
      {{else if (eq actionData.cost.movement.mode "variable")}}
        <input
          class="attack-config__cost-input"
          name="system.{{actionPath}}cost.movement.variable"
          type="text"
          value="{{actionData.cost.movement.variable}}"
          placeholder="X"
        />
      {{/if}}
    </div>

    <div class="attack-config__cost-entry">
      <span class="attack-config__cost-label">Nalfa</span>
      <input
        class="attack-config__cost-input"
        name="system.{{actionPath}}cost.nalfa.amount"
        type="number"
        value="{{actionData.cost.nalfa.amount}}"
        data-dtype="Number"
      />
      <select
        class="attack-config__cost-select attack-config__cost-select--nalfa"
        name="system.{{actionPath}}cost.nalfa.category"
      >
        {{selectOptions config.nalfa_cost_categories selected=actionData.cost.nalfa.category}}
      </select>
    </div>

    <div class="attack-config__cost-entry attack-config__cost-entry--nalfa-overload">
      <span class="attack-config__cost-label">Surcharge Nalfa</span>
      <div class="attack-config__nalfa-overload-fields">
        <label class="field field--inline attack-config__nalfa-overload-toggle">
          <input
            name="system.{{actionPath}}cost.nalfa.overload.enabled"
            type="checkbox"
            {{checked actionData.cost.nalfa.overload.enabled}}
          />
          <span>Compatible</span>
        </label>
        {{#if actionData.cost.nalfa.overload.enabled}}
          <input
            class="attack-config__cost-input"
            name="system.{{actionPath}}cost.nalfa.overload.amount"
            type="number"
            value="{{actionData.cost.nalfa.overload.amount}}"
            data-dtype="Number"
            placeholder="Nalfa supp."
          />
          <textarea
            class="attack-config__nalfa-overload-effect"
            name="system.{{actionPath}}cost.nalfa.overload.effect"
            placeholder="Effet ajouté ou augmenté"
          >{{actionData.cost.nalfa.overload.effect}}</textarea>
          <label class="field field--inline attack-config__nalfa-overload-toggle">
            <input
              name="system.{{actionPath}}cost.nalfa.overload.jdd.enabled"
              type="checkbox"
              {{checked actionData.cost.nalfa.overload.jdd.enabled}}
            />
            <span>JdD modifié</span>
          </label>
        {{/if}}
      </div>
    </div>

    {{#if actionData.cost.nalfa.overload.enabled}}
      {{#if actionData.cost.nalfa.overload.jdd.enabled}}
        <div class="attack-config__cost-entry attack-config__cost-entry--nalfa-overload-jdd">
          <span class="attack-config__cost-label">JdD surcharge</span>
          <div class="attack-config__fields">
            {{#each actionData.cost.nalfa.overload.jdd.damage_formulas as |damage index|}}
              {{>
                "systems/nalfa/templates/partials/item/actionable/damage-formula-row.hbs"
                actionPath=@root.actionPath
                damagePath="cost.nalfa.overload.jdd.damage_formulas"
                damage=damage
                index=index
                config=@root.config
                isActionModeIncant=@root.isActionModeIncant
                isActionModePhysical=@root.isActionModePhysical
                readonly=@root.readonly
                showAddButton=(eq index 0)
                addTooltip="Ajouter une formule de dégâts de surcharge"
                removeTooltip="Supprimer cette formule de dégâts de surcharge"
                formulaPlaceholder="Ex : 2d6m+1"
              }}
            {{/each}}
          </div>
        </div>
      {{/if}}
    {{/if}}

    <div class="attack-config__cost-entry">
      <span class="attack-config__cost-label">Utilisations</span>
      {{#unless (eq actionData.cost.uses.unit "none")}}
        <input
          class="attack-config__cost-input"
          name="system.{{actionPath}}cost.uses.value"
          type="number"
          value="{{actionData.cost.uses.value}}"
          data-dtype="Number"
        />
        <span class="field__separator">/</span>
        <input
          class="attack-config__cost-input"
          name="system.{{actionPath}}cost.uses.max"
          type="number"
          value="{{actionData.cost.uses.max}}"
          data-dtype="Number"
        />
      {{/unless}}
      <select
        class="attack-config__cost-select attack-config__cost-select--uses"
        name="system.{{actionPath}}cost.uses.unit"
      >
        {{selectOptions config.uses_units selected=actionData.cost.uses.unit}}
      </select>
    </div>

    <div class="attack-config__cost-entry">
      <span class="attack-config__cost-label">Cooldown</span>
      {{#unless (eq actionData.cost.cooldown.unit "none")}}
        <input
          class="attack-config__cost-input"
          name="system.{{actionPath}}cost.cooldown.amount"
          type="number"
          value="{{actionData.cost.cooldown.amount}}"
          data-dtype="Number"
        />
      {{/unless}}
      <select
        class="attack-config__cost-select attack-config__cost-select--cooldown"
        name="system.{{actionPath}}cost.cooldown.unit"
      >
        {{selectOptions config.cooldown_units selected=actionData.cost.cooldown.unit}}
      </select>
    </div>
  </div>
</div>
