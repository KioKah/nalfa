<div class="sheet-section">
  <h2>Nalfa</h2>
  <div class="grid grid--three">
    <div class="field field--inline nalfa-resource">
      <span class="field__label nalfa-resource__label">
        <i class="fa-light fa-sparkle nalfa-resource__icon"></i>
        <span>Nalfa</span>
      </span>
      <input
        name="system.nalfa.value"
        type="number"
        value="{{sysData.nalfa.value}}"
        data-dtype="Number"
      />
      <span class="field__separator">/</span>
      <input
        name="system.nalfa.max"
        type="number"
        value="{{sysData.nalfa.max}}"
        data-dtype="Number"
      />
    </div>
  </div>
</div>
