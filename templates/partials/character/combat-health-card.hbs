<div class="combat-overview__card">
  <div class="combat-overview__header">
    <div class="combat-overview__title">Santé</div>
  </div>
  <div class="combat-overview__separator"></div>
  <div class="field combat-overview__hp">
    <span class="field__label">PV</span>
    <input
      name="system.attributes.hp.value"
      type="number"
      value="{{sysData.attributes.hp.value}}"
      data-dtype="Number"
    />
    <span class="field__separator">/</span>
    <span class="field__total">{{sysData.attributes.hp.max}}</span>
    {{#if (eq sysData.ui.valueMode "values")}}
      {{#if (gt sysData.attributes.hp.value 0)}}
        <span class="field__meta field__meta--formula">
          ({{lookup config.profiles sysData.profile}}{{formulaSignedNumber sysData.attributes.hp.base}}{{formulaSignedNumber sysData.attributes.hp.alt}})
        </span>
      {{/if}}
    {{/if}}
    {{#if (eq sysData.ui.valueMode "base")}}
      <input
        class="combat-overview__hp-edit-input"
        name="system.attributes.hp.base"
        type="number"
        value="{{sysData.attributes.hp.base}}"
        data-dtype="Number"
      />
    {{else if (eq sysData.ui.valueMode "alt")}}
      <input
        class="combat-overview__hp-edit-input"
        name="system.attributes.hp.alt"
        type="number"
        value="{{sysData.attributes.hp.alt}}"
        data-dtype="Number"
      />
    {{/if}}
    {{#if isKO}}
      <span class="ko-indicator">
        {{#if deathTick.isDead}}Mort{{else}}KO{{/if}}
      </span>
    {{/if}}
  </div>
  <div class="combat-overview__line">
    {{#if (eq sysData.ui.valueMode "base")}}
      <label class="field field--inline combat-overview__entry">
        <span class="field__label">Profil</span>
        <select class="combat-overview__profile-select" name="system.profile">
          {{selectOptions config.profiles selected=sysData.profile}}
        </select>
      </label>
    {{else if (eq sysData.ui.valueMode "alt")}}
      <label class="field field--inline combat-overview__entry">
        <span class="field__label">Profil</span>
        <select class="combat-overview__profile-select" name="system.profile">
          {{selectOptions config.profiles selected=sysData.profile}}
        </select>
      </label>
    {{else}}
      {{#if isKO}}
        {{#if deathTick.isDead}}
          <div class="field field--inline combat-overview__entry combat-overview__entry--death-rip">
            <span class="combat-overview__value ko-indicator">RIP</span>
          </div>
        {{else}}
          <div class="field field--inline combat-overview__entry combat-overview__entry--death">
            <span class="combat-overview__death-main">
              <span class="field__label">Mort dans</span>
              <span class="field__total combat-overview__value">{{deathTick.turnsToDeath}}</span>
              <span class="field__meta">
                {{#if (eq deathTick.turnsToDeath 1)}}tour{{else}}tours{{/if}}
              </span>
            </span>
            <span class="combat-overview__rate combat-overview__death-rate">
              <span>(</span>
              <span>-{{deathTick.lossPerTurn}}</span>
              <span class="combat-overview__fraction">
                <span>PV</span>
                <span>tour</span>
              </span>
              <span>)</span>
            </span>
          </div>
        {{/if}}
      {{else}}
        <label class="field field--inline combat-overview__entry">
          <span class="field__label">Absorption</span>
          <input
            name="system.attributes.hp.abso"
            type="number"
            value="{{sysData.attributes.hp.abso}}"
            data-dtype="Number"
          />
        </label>
      {{/if}}
    {{/if}}
  </div>
</div>
