<div class="nalfa-chat-card nalfa-roll-card nalfa-chat-card--prompt">
	<header class="nalfa-roll-header">
		<h3 class="nalfa-roll-title">
			<span class="nalfa-roll-label">JdS</span>
			{{#if titleName}}
				<span class="nalfa-roll-separator">·</span>
				<span class="nalfa-roll-name">{{titleName}}</span>
			{{/if}}
		</h3>
	</header>
	<div class="nalfa-roll-summary">
		<span>
			{{#if targetName}}{{targetName}} · {{/if}}Sauv {{dc}} {{statLabel}}
			{{#if (formulaSignedNumber targetStatValue)}}({{formulaSignedNumber targetStatValue}}){{/if}}
			{{#if sourceTokenName}}contre {{sourceTokenName}}{{/if}}
		</span>
	</div>
	<div class="nalfa-roll-action">
		<button
			type="button"
			class="nalfa-roll-prompt"
			data-action="roll-jds"
			data-dc="{{dc}}"
			data-stat="{{statKey}}"
			data-name="{{titleName}}"
			data-stat-label="{{statLabel}}"
			data-stat-value="{{targetStatValue}}"
			data-target-token-uuid="{{targetTokenUuid}}"
			data-target-actor-uuid="{{targetActorUuid}}"
			data-source-token-uuid="{{sourceTokenUuid}}"
			data-source-token-name="{{sourceTokenName}}"
			data-context-id="{{contextId}}"
			data-source-item-uuid="{{sourceItemUuid}}"
			data-action-index="{{actionIndex}}"
			data-action-name="{{actionName}}"
			data-tooltip="Lancer le jet de sauvegarde"
		>
			Sauv {{dc}} {{statLabel}}
		</button>
	</div>
</div>
