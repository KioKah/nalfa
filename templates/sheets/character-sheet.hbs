    </div>

    <div class="attributes-container">
      <h2>Attributes</h2>
      {{!-- HP --}}
      <p>
        HP: <input name="system.attributes.hp.value" type="number" value="{{sysData.attributes.hp.value}}" data-dtype="Number"/> / <input name="system.attributes.hp.max" type="number" value="{{sysData.attributes.hp.max}}" data-dtype="Number"/>
      </p>
      {{!-- Currencies --}}
      <div>
        <h3>Monnaies :</h3>
        {{#if currencies}}
        <div class="currencies">
          {{#each currencies as |currency|}}
            {{> "systems/nalfa/templates/partials/character-sheet/currency.hbs" currency=currency}}
          {{/each}}
        </div>
        {{else}}
        (Pas de monnaies)
        {{/if}}
      </div>
    </div>
    <div class="Inventory">
      <h2>
        <div>
          Weapon
          <a class="item-create" data-dtype="Weapon" title="Create weapon">
            <i class="fas fa-plus"></i>
          </a>
        </div>
      </h2> 
      <section class="weapon-list">
        {{#each weapons as |weapon index|}}
        {{!-- index va de 0 à n-1 --}}
        {{> "systems/nalfa/templates/partials/weapon.hbs" item=weapon id=index}}
        {{/each}}
      </section>
    </div>
  </div>
</form>
