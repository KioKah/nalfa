<form class="character {{cssClass}}" autocomplete="off">
  <div class="nalfa-sheet">
    <div class="nalfa-sheet-header">
      <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
      <div class="nalfa-sheet-header-info">
        <div class="sheet-name">
          <input name="name" type="text" value="{{actor.name}}" placeholder="Name"/>
        </div>
        <span class="level">
          LV : <input name="system.attributes.level" type="number" value="{{sysData.attributes.level}}" data-dtype="Number"/>
        </span> 
      </div>
    </div>
    
    <h2>Stats {{numberFormat sysData.stats.str.value decimals=0 sign=true}}</h2>
    <div class="stats-container">
      {{!-- STR --}}
      <div class="stat-container">
        <div class="stat-box">
          <h2>
            <span class="stat-name">{{localize "nalfa.stats-short.str"}}</span>
            <label>
              <input class="hidden" name="system.stats.str.proficient" type="checkbox" {{checked sysData.stats.str.proficient}}/>
              {{#if sysData.stats.str.proficient}}
                <i class="fa-solid fa-star fa-sm"></i>
              {{else}}
                <i class="fa-regular fa-star fa-sm"></i>
              {{/if}}
            </label>
          </h2>
          <input class="stat" name="system.stats.str.value" type="number" value="{{sysData.stats.str.value}}" data-dtype="Number"/>
          <div class="stat-bonuses">
            <div class="stat-bonus">
              <p>Check</p>
              <input name="system.stats.str.bonuses.check" type="number" value="{{sysData.stats.str.bonuses.check}}" data-dtype="Number"/>
            </div>
            <div class="stat-bonus">
              <p>Save</p>
              <input name="system.stats.str.bonuses.save" type="number" value="{{sysData.stats.str.bonuses.save}}" data-dtype="Number"/>
            </div>
          </div>
        </div>
      </div>
      {{!-- DEX --}}
      <div class="stat-container">
        <div class="stat-box">
          <h2>
            <span class="stat-name">{{localize "nalfa.stats-short.dex"}}</span>
