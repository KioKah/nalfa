  <input type="button"/><br/>
  checkbox
  <input type="checkbox"/><br/>
  color
  <input type="color"/><br/>
  date
  <input type="date"/><br/>
  datetime-local
  <input type="datetime-local"/><br/>
  email
  <input type="email"/><br/>
  file
  <input type="file"/><br/>
  hidden
  <input type="hidden"/><br/>
  image
  <input type="image"/><br/>
  month
  <input type="month"/><br/>
  password
  <input type="password"/><br/>
  radio
  <input type="radio" name="radio1"/><br/>
