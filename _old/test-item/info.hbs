  <input type="range" value="4" min="1" max="10" step="1" oninput="this.nextElementSibling.value = this.value"/> Value : <output>4</output><br/>
  reset
  <input type="reset"/><br/>
  search
  <input type="search"/><br/>
  submit
  <input type="submit"/><br/>
  tel
  <input type="tel"/><br/>
  time
  <input type="time"/><br/>
  url
  <input type="url"/><br/>
