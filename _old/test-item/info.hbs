    </tr>
  </thead>
  <tbody>
    <tr>
      <td>tbody (table body)</td>
      <td>→tr (table row) </td>
      <td>→→th (table cell)</td>
    </tr>
  </tbody>
  <tfoot>
    <tr>
      <td>tbody (table body)</td>
