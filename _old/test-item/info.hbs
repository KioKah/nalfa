<form>
  <label for="select">[select] label</label>
  <select name="select" id="select" aria-placeholder="select">
    <optgroup label="optgroup 1">
      <option value="option1-1">option 1-1</option>
      <option value="option1-2">option 1-2</option>
    </optgroup>
    <optgroup label="optgroup 2">
      <option value="option2-1">option 2-1</option>
      <option value="option2-2">option 2-2</option>
    </optgroup>
  </select><br/>

  <textarea id="textarea" name="textarea" rows="2" cols="9">textarea</textarea><br/>

  <label for="progress">[progress] label : </label>
  <progress id="progress" value="32" max="100">progress</progress><br/>

  <label for="meter">[meter] label : </label>
  <meter id="meter" value="0.6">meter [0.6]</meter><br/>

  <h2>All input types</h2>

  text
  <input type="text" id="text-input" name="text-input" placeholder="text input"/><br/>
